# Arcis — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# A strong secret key used to authenticate API requests.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
ARCIS_API_KEY=bbedb792038a7bc1bc79b1765f4bf4dbbb842a8a6a19b35e9c2fbbb26640c551

# Comma-separated list of allowed frontend origins (no trailing slash).
# Example for Render: https://arcis-dvgq.onrender.com
ARCIS_ALLOWED_ORIGINS=https://arcis-dvgq.onrender.com

# Set to "production" to enforce strict CORS and disable debug output.
ENV=production

# Port the server listens on (Render sets this automatically).
PORT=5001
